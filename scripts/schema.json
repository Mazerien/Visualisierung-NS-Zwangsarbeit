{
    "person": [
        "CREATE TABLE IF NOT EXISTS `person` (",
        "`id` INT NOT NULL AUTO_INCREMENT,",
        "`source` VARCHAR(255),",
        "`last_name` VARCHAR(255) NOT NULL,",
        "`first_name` VARCHAR(255) NOT NULL,",
        "`maiden_name` VARCHAR(255),",
        "`alt_last_name_1` VARCHAR(255),",
        "`alt_last_name_2` VARCHAR(255),",
        "`alt_first_name_1` VARCHAR(255),",
        "`alt_first_name_2` VARCHAR(255),",
        "`gender` ENUM('Male', 'Female', 'Other') NOT NULL,",
        "`place_birth` VARCHAR(255),",
        "`place_birth_alt_name` VARCHAR(255),",
        "`place_birth_geo_coord` POINT,",
        "`alt_place_birth` VARCHAR(255),",
        "`alt_place_birth_alt_name` VARCHAR(255),",
        "`alt_place_birth_geo_coord` POINT,",
        "`date_birth` DATE,",
        "`alt_date_birth` DATE,",
        "`place_death` VARCHAR(255),",
        "`place_death_alt_name` VARCHAR(255),",
        "`place_death_geo_coord` POINT,",
        "`alt_place_death` VARCHAR(255),",
        "`alt_place_death_alt_name` VARCHAR(255),",
        "`alt_place_death_geo_coord` POINT,",
        "`date_death` DATE,",
        "`alt_date_death` DATE,",
        "`category` SET('Civilian', 'PoW', 'ConcentrCamp', 'Other'),",
        "`nationality` VARCHAR(255),",
        "`alt_nationality` VARCHAR(255),",
        "`citizenship` VARCHAR(255),",
        "`last_place_residence` VARCHAR(255),",
        "`marriage` VARCHAR(255),",
        "`mother` VARCHAR(255),",
        "`father` VARCHAR(255),",
        "`religion` VARCHAR(255),",
        "`profession` VARCHAR(255),",
        "`alt_profession` VARCHAR(255),",
        "`files` TEXT,",
        "`remarks` TEXT,",
        "PRIMARY KEY (`id`)",
        ") ENGINE=InnoDB"
    ],

    "company": [
        "CREATE TABLE IF NOT EXISTS `company` (",
        "`id` INT NOT NULL AUTO_INCREMENT,",
        "`name_comp_hist` VARCHAR(255),",
        "`alt_name_comp_hist` VARCHAR(255),",
        "`alt_name_comp_hist_2` VARCHAR(255),",
        "`industry_comp` SET('TODO'),",
        "`start_comp` DATE,",
        "`end_comp` DATE,",
        "`still_existent` ENUM('Yes', 'No', 'SomeWay'),",
        "`leadership_hist` TEXT,",
        "`number_employees_hist` VARCHAR(255),",
        "`name_comp_today` VARCHAR(255),",
        "`events_history_company` TEXT,",
        "`photos` TINYINT(1),",
        "`location_comp_name` VARCHAR(255),",
        "`location_comp_municipality_today` VARCHAR(255),",
        "`location_comp_village_neighborhood_today` VARCHAR(255),",
        "`location_comp_street_name_today` VARCHAR(255),",
        "`location_comp_house_number_today` VARCHAR(50),",
        "`location_comp_street_name_hist` VARCHAR(255),",
        "`location_comp_house_number_hist` VARCHAR(50),",
        "`location_comp_geo_coord` POINT,",
        "`alt_location_comp1_name` VARCHAR(255),",
        "`alt_location_comp1_municipality_today` VARCHAR(255),",
        "`alt_location_comp1_village_neighborhood_today` VARCHAR(255),",
        "`alt_location_comp1_street_name_today` VARCHAR(255),",
        "`alt_location_comp1_house_number_today` VARCHAR(50),",
        "`alt_location_comp1_street_name_hist` VARCHAR(255),",
        "`alt_location_comp1_house_number_hist` VARCHAR(50),",
        "`alt_location_comp1_geo_coord` POINT,",
        "`alt_location_comp2_name` VARCHAR(255),",
        "`alt_location_comp2_municipality_today` VARCHAR(255),",
        "`alt_location_comp2_village_neighborhood_today` VARCHAR(255),",
        "`alt_location_comp2_street_name_today` VARCHAR(255),",
        "`alt_location_comp2_house_number_today` VARCHAR(50),",
        "`alt_location_comp2_street_name_hist` VARCHAR(255),",
        "`alt_location_comp2_house_number_hist` VARCHAR(50),",
        "`alt_location_comp2_geo_coord` POINT,",
        "`other_location_outside_schwenningen` TEXT,",
        "`files` TEXT,",
        "`remarks` TEXT,",
        "PRIMARY KEY (`id`)",
        ") ENGINE=InnoDB"
    ],

    "employment": [
        "CREATE TABLE IF NOT EXISTS `employment` (",
        "`id` INT NOT NULL AUTO_INCREMENT,",
        "`person_id` INT,",
        "`company_id` INT,",
        "`location` VARCHAR(255),",
        "`department` VARCHAR(255),",
        "`occupation` VARCHAR(255),",
        "`start_date` DATE,",
        "`end_date` DATE,",
        "`remarks` TEXT,",
        "PRIMARY KEY (`id`),",
        "FOREIGN KEY (`person_id`) REFERENCES `person`(`id`) ON DELETE CASCADE,",
        "FOREIGN KEY (`company_id`) REFERENCES `company`(`id`) ON DELETE CASCADE",
        ") ENGINE=InnoDB"
    ],

    "housing": [
        "CREATE TABLE IF NOT EXISTS `housing` (",
        "`id` INT NOT NULL AUTO_INCREMENT,",
        "`location` ENUM('Schwenningen', 'Regional', 'Other'),",
        "`type` SET('Lager', 'andereGemeinschaftsunterkunft', 'Privat', 'Haftort', 'Sonstiges'),",
        "`name_place` VARCHAR(255),",
        "`alt_name_place` VARCHAR(255),",
        "`alt_name_place_2` VARCHAR(255),",
        "`country_today` VARCHAR(255),",
        "`province_today` VARCHAR(255),",
        "`district_today` VARCHAR(255),",
        "`municipality_today` VARCHAR(255),",
        "`village_neighborhood_today` VARCHAR(255),",
        "`street_name_today` VARCHAR(255),",
        "`house_number_today` VARCHAR(50),",
        "`geo_coord` POINT,",
        "`country_hist` VARCHAR(255),",
        "`alt_country_hist` VARCHAR(255),",
        "`province_hist` VARCHAR(255),",
        "`alt_province_hist` VARCHAR(255),",
        "`district_hist` VARCHAR(255),",
        "`alt_district_hist` VARCHAR(255),",
        "`municipality_hist` VARCHAR(255),",
        "`alt_municipality_hist` VARCHAR(255),",
        "`village_neighborhood_hist` VARCHAR(255),",
        "`alt_village_neighborhood_hist` VARCHAR(255),",
        "`street_name_hist` VARCHAR(255),",
        "`alt_street_name_hist` VARCHAR(255),",
        "`house_number_hist` VARCHAR(50),",
        "`alt_house_number_hist` VARCHAR(50),",
        "`date_construction_building` DATE,",
        "`owner_hist` VARCHAR(255),",
        "`alt_owner_hist` VARCHAR(255),",
        "`owner_today` VARCHAR(255),",
        "`events_history_of_place` TEXT,",
        "`photos` TINYINT(1),",
        "`building_still_existent` ENUM('Yes', 'No', 'Partially', 'Not Relevant'),",
        "`files` TEXT,",
        "`remarks` TEXT,",
        "PRIMARY KEY (`id`)",
        ") ENGINE=InnoDB"
    ],

    "tenancy": [
        "CREATE TABLE IF NOT EXISTS `tenancy` (",
        "`id` INT NOT NULL AUTO_INCREMENT,",
        "`person_id` INT,",
        "`housing_id` INT,",
        "`start_date` DATE,",
        "`end_date` DATE,",
        "`remarks` TEXT,",
        "PRIMARY KEY (`id`),",
        "FOREIGN KEY (`person_id`) REFERENCES `person`(`id`) ON DELETE CASCADE,",
        "FOREIGN KEY (`housing_id`) REFERENCES `housing`(`id`) ON DELETE CASCADE",
        ") ENGINE=InnoDB"
    ],

    "imprisonment": [
        "CREATE TABLE IF NOT EXISTS `imprisonment` (",
        "`id` INT NOT NULL AUTO_INCREMENT,",
        "`person_id` INT,",
        "`housing_id` INT,",
        "`imprisonment_id` VARCHAR(255),",
        "`alt_prisoner_id` VARCHAR(255),",
        "`category_reason` VARCHAR(255),",
        "`start_date` DATE,",
        "`end_date` DATE,",
        "`court_of_law` VARCHAR(255),",
        "`remarks` TEXT,",
        "PRIMARY KEY (`id`),",
        "FOREIGN KEY (`person_id`) REFERENCES `person`(`id`) ON DELETE CASCADE,",
        "FOREIGN KEY (`housing_id`) REFERENCES `housing`(`id`) ON DELETE CASCADE",
        ") ENGINE=InnoDB"
    ]
}